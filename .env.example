# Copy to .env and adjust. All variables are optional — see
# src/nairatax/config.py for defaults. Every key is prefixed NAIRATAX_ and
# read via pydantic-settings.

# Horizon endpoint and matching network passphrase. Defaults to testnet —
# uncomment the mainnet pair below deliberately, don't just swap the URL.
# NAIRATAX_HORIZON_URL=https://horizon-testnet.stellar.org
# NAIRATAX_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# NAIRATAX_HORIZON_URL=https://horizon.stellar.org
# NAIRATAX_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015

# Reporting currency (ISO 4217) and default jurisdiction rule pack
# (rules/packs/<jurisdiction>.yaml).
# NAIRATAX_REPORTING_CURRENCY=NGN
# NAIRATAX_JURISDICTION=nigeria

# Where cached data and generated reports are written.
# NAIRATAX_DATA_DIR=./data

# Horizon paging/timeout tuning.
# NAIRATAX_HORIZON_PAGE_LIMIT=200
# NAIRATAX_HORIZON_REQUEST_TIMEOUT_SECONDS=30
